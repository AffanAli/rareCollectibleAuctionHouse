PORT=3000
# Comma-separated origins for CORS, or omit to reflect the default (allow all in dev)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# PostgreSQL (match docker-compose defaults or your local install)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auction_house

# Set to true to run pending migrations on app startup (optional)
# DB_MIGRATIONS_RUN=false

# TypeORM SQL logging
# DB_LOGGING=false
